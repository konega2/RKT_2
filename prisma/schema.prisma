generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("PRISMA_DATABASE_URL")
}

model Pilot {
  id                String    @id @default(cuid())
  name              String
  age               Int
  dni               String
  phone             String
  email             String
  category          String
  status            String
  photo             String?
  internalNotes     String    @default("")
  insuranceAccepted Boolean   @default(false)
  liabilitySigned   Boolean   @default(false)
  imageAccepted     Boolean   @default(false)
  confirmedAt       DateTime?
  confirmedBy       String    @default("Panel RKT")
  createdAt         DateTime  @default(now())
  comments          Comment[]

  @@index([name])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  pilotId   String
  pilot     Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@index([pilotId])
}
