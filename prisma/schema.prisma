generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("PRISMA_DATABASE_URL")
}

enum PilotStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TrainingSanctionType {
  time_penalty
  lap_deleted
}

model Pilot {
  id                String    @id @default(cuid())
  name              String
  age               Int
  dni               String
  phone             String
  email             String
  category          String[]
  status            PilotStatus @default(PENDING)
  photo             String?
  internalNotes     String    @default("")
  insuranceAccepted Boolean   @default(false)
  liabilitySigned   Boolean   @default(false)
  imageAccepted     Boolean   @default(false)
  confirmedAt       DateTime?
  confirmedBy       String    @default("Panel RKT")
  createdAt         DateTime  @default(now())
  comments          Comment[]
  assignments       TrainingAssignment[]
  laps              TrainingLap[]
  sanctions         TrainingSanction[]

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  pilotId   String
  pilot     Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@index([pilotId])
}

model TrainingSession {
  id          String               @id @default(cuid())
  name        String
  time        String
  duration    Int
  maxPilots   Int                  @default(24)
  assignments TrainingAssignment[]
  laps        TrainingLap[]
  sanctions   TrainingSanction[]

  @@index([time])
}

model TrainingAssignment {
  id        String          @id @default(cuid())
  pilotId   String
  sessionId String
  pilot     Pilot           @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([pilotId, sessionId])
  @@index([pilotId])
  @@index([sessionId])
}

model TrainingLap {
  id        String          @id @default(cuid())
  pilotId   String
  pilotName String
  kart      String
  tiempo    Float
  lapNumber Int
  createdAt DateTime        @default(now())
  sessionId String
  pilot     Pilot           @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([pilotId])
  @@index([lapNumber])
  @@index([createdAt])
}

model TrainingSanction {
  id        String               @id @default(cuid())
  pilotId   String
  tipo      TrainingSanctionType
  valor     Float                @default(0)
  vueltas   Int[]
  motivo    String
  createdAt DateTime             @default(now())
  sessionId String
  pilot     Pilot                @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  session   TrainingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([pilotId])
  @@index([createdAt])
}
